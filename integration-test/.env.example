# `aio app use` populates these from the selected project/workspace.
# Lowercase `runtime` matches what the aio CLI writes; uppercase is also
# accepted by the live test script.
AIO_runtime_namespace=
AIO_runtime_auth=

# Inputs consumed by the `params` action (see app.config.yaml).
# Leave unset to verify the validation-failure path; set both to verify the
# success path.
MY_INPUT_VAR=hello
MY_OTHER_INPUT=world

# Optional override: full base URL of the deployed package (skips namespace
# lookup). Useful for staging/prod or for testing behind a proxy.
# Example: https://my-ns.adobeioruntime.net/api/v1/web/adapter-integration-test
# DEPLOYED_BASE_URL=
